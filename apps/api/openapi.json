  "info": {
    "contact": {
      "name": "KW Pipeline",
      "url": "https://github.com/SofianeBENHELLI/KW-Pipeline"
    },
    "description": "Auditable document-intelligence pipeline. Endpoints cover upload, hashing, duplicate detection, parsing, semantic-JSON generation, reviewer validate/reject, and an optional knowledge-graph projection (ADR-012). Every claim and edge carries provenance via `source_reference_id`. See `docs/architecture/document_intelligence_mvp.md` for the ingestion contract and `docs/architecture/api_contract.md` for the public response shapes.",
    "license": {
      "name": "Proprietary — all rights reserved",
      "url": "https://github.com/SofianeBENHELLI/KW-Pipeline/blob/main/LICENSE"
    },
    "title": "KW Pipeline Harvester API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/documents": {
      "get": {
        "operationId": "list_documents",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentListResponse"
                }
              }
            },
            "description": "Successful Response"
