      "GraphEdge": {
        "description": "One directed edge in the knowledge graph projection.\n\n``source_id`` and ``target_id`` reference :class:`GraphNode.id`\nvalues. Provenance requirements depend on ``kind``:\n\n- **structural** (``part_of``, ``has_version``, ``has_chunk``,\n  ``belongs_to``) — no citation required; the edge itself is the\n  provenance.\n- **deterministic semantic** (``related_to``, ``shares_keyword``,\n  ``same_topic_as``) — must carry ``source_chunk_ids`` (the two\n  chunks that produced the relation), ``reason`` (human-readable\n  explanation), and ``shared_keywords`` in ``properties``. See\n  :class:`ChunkRelationEdgeProperties`.\n- **LLM** (``has_entity``) — must carry ``source_reference_id``\n  pointing at a row in the catalog's ``source_references`` table\n  (ADR-012 §4). Triples missing citations are dropped by the\n  extractor before edges are constructed.",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "kind": {
            "enum": [
              "part_of",
              "has_version",
              "has_chunk",
              "belongs_to",
              "related_to",
              "shares_keyword",
              "same_topic_as",
              "has_entity"
            ],
            "title": "Kind",
            "type": "string"
          },
          "properties": {
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ]
            },
            "title": "Properties",
            "type": "object"
          },
          "source_id": {
            "title": "Source Id",
            "type": "string"
          },
          "target_id": {
            "title": "Target Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "kind",
          "source_id",
          "target_id",
          "properties"
        ],
        "title": "GraphEdge",
        "type": "object"
      },
      "GraphNode": {
        "description": "One node in the knowledge graph projection.\n\n``id`` is stable across projections — for ``document`` and\n``version`` nodes it matches the catalog row ID; for ``section`` /\n``chunk`` nodes it matches ``SemanticSection.id``; for ``topic``\nnodes it is a deterministic id from the clustering service (see\n:class:`TopicNodeProperties`); for ``entity`` nodes (Phase 2) it is\na deterministic hash of (text, type) so re-runs converge on the\nsame node.",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "kind": {
            "enum": [
              "document",
              "version",
              "section",
              "chunk",
              "topic",
              "entity"
            ],
            "title": "Kind",
            "type": "string"
          },
          "label": {
            "title": "Label",
            "type": "string"
          },
          "properties": {
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ]
            },
            "title": "Properties",
            "type": "object"
          }
        },
        "required": [
          "id",
          "kind",
          "label",
          "properties"
        ],
        "title": "GraphNode",
        "type": "object"
      },
