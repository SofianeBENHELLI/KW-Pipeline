      "RawSection": {
        "description": "Typed parser-produced section.\n\nCarries the minimum fields needed for semantic extraction plus optional\nplaceholders for fields that future parsers (e.g. Docling for PDFs) will\npopulate. Keeping the schema explicit avoids the historical\n``list[dict]`` shape and the ``.get()``-driven access pattern that came\nwith it.",
        "properties": {
          "bbox": {
            "anyOf": [
              {
                "maxItems": 4,
                "minItems": 4,
                "prefixItems": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bbox"
          },
          "heading": {
            "default": "Extracted Text",
            "title": "Heading",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "page_number": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Page Number"
          },
          "parser_metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Parser Metadata",
            "type": "object"
          },
          "source_reference_ids": {
            "items": {
              "type": "string"
            },
            "title": "Source Reference Ids",
            "type": "array"
          },
          "text": {
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "id",
          "heading",
          "text",
          "source_reference_ids",
          "page_number",
          "bbox",
          "parser_metadata"
        ],
        "title": "RawSection",
        "type": "object"
      },
