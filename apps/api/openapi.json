{
  "components": {
    "schemas": {
      "Body_upload_document": {
        "properties": {
          "file": {
            "format": "binary",
            "title": "File",
            "type": "string"
          }
        },
        "required": [
          "file"
        ],
        "title": "Body_upload_document",
        "type": "object"
      },
      "Document": {
        "description": "Logical document family containing one or more versions.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "latest_version_id": {
            "title": "Latest Version Id",
            "type": "string"
          },
          "original_filename": {
            "title": "Original Filename",
            "type": "string"
          },
          "versions": {
            "items": {
              "$ref": "#/components/schemas/DocumentVersion"
            },
            "title": "Versions",
            "type": "array"
          }
        },
        "required": [
          "id",
          "original_filename",
          "latest_version_id",
          "created_at",
          "versions"
        ],
        "title": "Document",
        "type": "object"
      },
      "DocumentListResponse": {
        "description": "Cursor-paginated page of documents returned by ``GET /documents``.",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/Document"
            },
            "title": "Items",
            "type": "array"
          },
          "next_cursor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Cursor"
          }
        },
        "required": [
          "items",
          "next_cursor"
        ],
        "title": "DocumentListResponse",
        "type": "object"
      },
      "DocumentProfile": {
        "description": "High-level metadata used at the top of semantic Markdown output.",
        "properties": {
          "audience": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Audience"
          },
          "document_type": {
            "default": "unknown",
            "title": "Document Type",
            "type": "string"
          },
          "executive_summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Executive Summary"
          },
          "purpose": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Purpose"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "title",
          "document_type",
          "purpose",
          "audience",
          "executive_summary"
        ],
        "title": "DocumentProfile",
        "type": "object"
      },
      "DocumentVersion": {
        "description": "One immutable binary upload in the catalog.",
        "properties": {
          "content_type": {
            "title": "Content Type",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "document_id": {
            "title": "Document Id",
            "type": "string"
          },
          "duplicate_of_version_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duplicate Of Version Id"
          },
          "failure_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failure Reason"
          },
          "file_size": {
            "title": "File Size",
            "type": "integer"
          },
          "filename": {
            "title": "Filename",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "reviewed_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reviewed At"
          },
          "reviewer_note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reviewer Note"
          },
          "sha256": {
            "title": "Sha256",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/DocumentVersionStatus"
          },
          "storage_uri": {
            "title": "Storage Uri",
            "type": "string"
          },
          "version_number": {
            "title": "Version Number",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "document_id",
          "version_number",
          "filename",
          "content_type",
          "file_size",
          "sha256",
          "storage_uri",
          "status",
          "duplicate_of_version_id",
          "failure_reason",
          "reviewer_note",
          "reviewed_at",
          "created_at"
        ],
        "title": "DocumentVersion",
        "type": "object"
      },
      "DocumentVersionStatus": {
        "enum": [
          "UPLOADED",
          "HASHED",
          "DUPLICATE_DETECTED",
          "STORED",
          "EXTRACTING",
          "EXTRACTED",
          "SEMANTIC_READY",
          "NEEDS_REVIEW",
          "VALIDATED",
          "REJECTED",
          "FAILED"
        ],
        "title": "DocumentVersionStatus",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "RawExtraction": {
        "description": "Inspectable parser output stored before semantic extraction.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "document_version_id": {
            "title": "Document Version Id",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "parser_name": {
            "title": "Parser Name",
            "type": "string"
          },
          "parser_version": {
            "title": "Parser Version",
            "type": "string"
          },
          "sections": {
            "items": {
              "$ref": "#/components/schemas/RawSection"
            },
            "title": "Sections",
            "type": "array"
          },
          "source_references": {
            "items": {
              "$ref": "#/components/schemas/SourceReference"
            },
            "title": "Source References",
            "type": "array"
          },
          "text": {
            "title": "Text",
            "type": "string"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "title": "Warnings",
            "type": "array"
          }
        },
        "required": [
          "id",
          "document_version_id",
          "parser_name",
          "parser_version",
          "text",
          "sections",
          "source_references",
          "warnings",
          "created_at"
        ],
        "title": "RawExtraction",
        "type": "object"
      },
      "RawSection": {
        "description": "Typed parser-produced section.\n\nCarries the minimum fields needed for semantic extraction plus optional\nplaceholders for fields that future parsers (e.g. Docling for PDFs) will\npopulate. Keeping the schema explicit avoids the historical\n``list[dict]`` shape and the ``.get()``-driven access pattern that came\nwith it.",
        "properties": {
          "bbox": {
            "anyOf": [
              {
                "maxItems": 4,
                "minItems": 4,
                "prefixItems": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bbox"
          },
          "heading": {
            "default": "Extracted Text",
            "title": "Heading",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "page_number": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Page Number"
          },
          "parser_metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Parser Metadata",
            "type": "object"
          },
          "source_reference_ids": {
            "items": {
              "type": "string"
            },
            "title": "Source Reference Ids",
            "type": "array"
          },
          "text": {
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "id",
          "heading",
          "text",
          "source_reference_ids",
          "page_number",
          "bbox",
          "parser_metadata"
        ],
        "title": "RawSection",
        "type": "object"
      },
      "ReviewRequest": {
        "description": "Optional reviewer note attached to a validate or reject decision.",
        "properties": {
          "reviewer_note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reviewer Note"
          }
        },
        "title": "ReviewRequest",
        "type": "object"
      },
      "SemanticAsset": {
        "description": "Typed semantic claim or asset extracted from the document.",
        "properties": {
          "confidence": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "type": "number"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "review_status": {
            "default": "needs_review",
            "enum": [
              "needs_review",
              "source_backed",
              "validated",
              "rejected"
            ],
            "title": "Review Status",
            "type": "string"
          },
          "source_reference_ids": {
            "items": {
              "type": "string"
            },
            "title": "Source Reference Ids",
            "type": "array"
          },
          "text": {
            "title": "Text",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "id",
          "type",
          "text",
          "confidence",
          "review_status",
          "source_reference_ids"
        ],
        "title": "SemanticAsset",
        "type": "object"
      },
      "SemanticDocument": {
        "description": "Governed semantic output for one document version.",
        "properties": {
          "assets": {
            "items": {
              "$ref": "#/components/schemas/SemanticAsset"
            },
            "title": "Assets",
            "type": "array"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "document_profile": {
            "$ref": "#/components/schemas/DocumentProfile"
          },
          "document_version_id": {
            "title": "Document Version Id",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "markdown": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Markdown"
          },
          "schema_version": {
            "const": "v0.1",
            "default": "v0.1",
            "title": "Schema Version",
            "type": "string"
          },
          "sections": {
            "items": {
              "$ref": "#/components/schemas/SemanticSection"
            },
            "title": "Sections",
            "type": "array"
          },
          "source_references": {
            "items": {
              "type": "object"
            },
            "title": "Source References",
            "type": "array"
          },
          "validation_status": {
            "default": "needs_review",
            "enum": [
              "needs_review",
              "validated",
              "rejected"
            ],
            "title": "Validation Status",
            "type": "string"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "title": "Warnings",
            "type": "array"
          }
        },
        "required": [
          "id",
          "document_version_id",
          "schema_version",
          "document_profile",
          "sections",
          "assets",
          "warnings",
          "source_references",
          "validation_status",
          "markdown",
          "created_at"
        ],
        "title": "SemanticDocument",
        "type": "object"
      },
      "SemanticSection": {
        "description": "Reviewable semantic section with optional source lineage.",
        "properties": {
          "heading": {
            "title": "Heading",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "source_reference_ids": {
            "items": {
              "type": "string"
            },
            "title": "Source Reference Ids",
            "type": "array"
          },
          "text": {
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "id",
          "heading",
          "text",
          "source_reference_ids"
        ],
        "title": "SemanticSection",
        "type": "object"
      },
      "SourceReference": {
        "description": "Pointer from extracted or semantic content back to source text.",
        "properties": {
          "document_version_id": {
            "title": "Document Version Id",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "line_end": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Line End"
          },
          "line_start": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Line Start"
          },
          "page_number": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Page Number"
          },
          "section_id": {
            "title": "Section Id",
            "type": "string"
          },
          "snippet": {
            "title": "Snippet",
            "type": "string"
          }
        },
        "required": [
          "id",
          "document_version_id",
          "section_id",
          "page_number",
          "line_start",
          "line_end",
          "snippet"
        ],
        "title": "SourceReference",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "KW Pipeline Harvester API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/documents": {
      "get": {
        "operationId": "list_documents",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentListResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Documents"
      }
    },
    "/documents/upload": {
      "post": {
        "operationId": "upload_document",
        "parameters": [
          {
            "in": "query",
            "name": "document_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Document Id"
            }
          },
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Idempotency-Key"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_document"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentVersion"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Upload Document"
      }
    },
    "/documents/{document_id}": {
      "get": {
        "operationId": "get_document",
        "parameters": [
          {
            "in": "path",
            "name": "document_id",
            "required": true,
            "schema": {
              "title": "Document Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Document"
      }
    },
    "/documents/{document_id}/versions/{version_id}/extract": {
      "post": {
        "operationId": "extract_version",
        "parameters": [
          {
            "in": "path",
            "name": "document_id",
            "required": true,
            "schema": {
              "title": "Document Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "version_id",
            "required": true,
            "schema": {
              "title": "Version Id",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Idempotency-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RawExtraction"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Extract Document"
      }
    },
    "/documents/{document_id}/versions/{version_id}/extraction": {
      "get": {
        "operationId": "get_extraction",
        "parameters": [
          {
            "in": "path",
            "name": "document_id",
            "required": true,
            "schema": {
              "title": "Document Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "version_id",
            "required": true,
            "schema": {
              "title": "Version Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RawExtraction"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Extraction"
      }
    },
    "/documents/{document_id}/versions/{version_id}/markdown": {
      "get": {
        "operationId": "get_markdown",
        "parameters": [
          {
            "in": "path",
            "name": "document_id",
            "required": true,
            "schema": {
              "title": "Document Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "version_id",
            "required": true,
            "schema": {
              "title": "Version Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              },
              "text/markdown": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Generated Markdown for the version."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Markdown"
      }
    },
    "/documents/{document_id}/versions/{version_id}/reject": {
      "post": {
        "operationId": "reject_version",
        "parameters": [
          {
            "in": "path",
            "name": "document_id",
            "required": true,
            "schema": {
              "title": "Document Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "version_id",
            "required": true,
            "schema": {
              "title": "Version Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
