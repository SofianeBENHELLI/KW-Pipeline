          "edges": {
            "items": {
              "$ref": "#/components/schemas/GraphEdge"
            },
            "title": "Edges",
            "type": "array"
          },
          "next_cursor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Cursor"
          },
          "nodes": {
            "items": {
              "$ref": "#/components/schemas/GraphNode"
            },
            "title": "Nodes",
            "type": "array"
          },
          "schema_version": {
            "default": "v0.2",
            "enum": [
              "v0.1",
              "v0.2"
            ],
            "title": "Schema Version",
            "type": "string"
          }
        },
        "required": [
          "schema_version",
          "nodes",
          "edges",
          "next_cursor"
        ],
        "title": "KnowledgeGraphPage",
        "type": "object"
      },
      "KnowledgeGraphProjection": {
        "description": "Subgraph for one document family — nodes and edges that the\nprojector wrote on the most recent ``VALIDATED`` transition.\n\nThe projection is deterministic with respect to its inputs: the\nsame ``Document`` + ``DocumentVersion`` + ``SemanticDocument`` will\nalways produce the same nodes and edges (modulo ``generated_at``).\nRe-projecting is safe — upserts are idempotent.",
        "properties": {
          "document_id": {
            "title": "Document Id",
            "type": "string"
          },
          "edges": {
            "items": {
              "$ref": "#/components/schemas/GraphEdge"
            },
            "title": "Edges",
            "type": "array"
          },
          "generated_at": {
            "format": "date-time",
            "title": "Generated At",
            "type": "string"
          },
          "nodes": {
            "items": {
              "$ref": "#/components/schemas/GraphNode"
            },
            "title": "Nodes",
            "type": "array"
          },
          "schema_version": {
            "default": "v0.2",
            "enum": [
              "v0.1",
              "v0.2"
            ],
            "title": "Schema Version",
            "type": "string"
          },
          "version_id": {
            "title": "Version Id",
            "type": "string"
          }
        },
        "required": [
          "schema_version",
          "document_id",
          "version_id",
          "nodes",
          "edges",
          "generated_at"
        ],
        "title": "KnowledgeGraphProjection",
        "type": "object"
      },
