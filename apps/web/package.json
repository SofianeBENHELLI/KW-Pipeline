{
  "name": "@kw-pipeline/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Orbital — KW Pipeline reviewer frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "openapi:export-backend": "cd ../api && python scripts/export_openapi.py",
    "openapi:generate": "openapi-typescript ../api/openapi.json -o src/api/generated/schema.ts",
    "openapi:check": "openapi-typescript ../api/openapi.json -o /tmp/kw-schema.check.ts && diff -u src/api/generated/schema.ts /tmp/kw-schema.check.ts",
    "bundle:check": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@neo4j-nvl/base": "^1.1.0",
    "@neo4j-nvl/react": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.11.4",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "openapi-fetch": "^0.13.8",
    "openapi-typescript": "^7.13.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@neo4j-nvl/base": {
      "lodash": "^4.18.1",
      "uuid": "^14.0.0"
    },
    "@neo4j-nvl/interaction-handlers": {
      "lodash": "^4.18.1"
    },
    "@neo4j-nvl/react": {
      "lodash": "^4.18.1"
    },
    "@neo4j-nvl/layout-workers": {
      "lodash": "^4.18.1"
    }
  }
}
