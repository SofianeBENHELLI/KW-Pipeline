{
  "name": "@kw-pipeline/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Orbital — KW Pipeline reviewer frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "openapi:export-backend": "cd ../api && python scripts/export_openapi.py",
    "openapi:generate": "openapi-typescript ../api/openapi.json -o src/api/generated/schema.ts",
    "openapi:check": "openapi-typescript ../api/openapi.json -o /tmp/kw-schema.check.ts && diff -u src/api/generated/schema.ts /tmp/kw-schema.check.ts",
    "bundle:check": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@neo4j-nvl/base": "^0.3.6",
    "@neo4j-nvl/react": "^0.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "openapi-fetch": "^0.13.8",
    "openapi-typescript": "^7.13.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
