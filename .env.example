# KW-Pipeline — environment configuration template
# ----------------------------------------------------
# Copy this file to `.env` (already gitignored) and fill in real values.
# `.env` is NOT auto-loaded by the API — settings come from the process
# environment. Either source the file before launching:
#
#   set -a && source .env && set +a
#   make demo-api
#
# …or export the relevant vars in your shell / deployment secrets manager.
#
# See README.md and apps/api/app/settings.py for the full surface.
# Every key uses the canonical `KW_*` prefix; legacy aliases without
# the prefix (e.g. `ANTHROPIC_API_KEY`) are still accepted.

# ─── Knowledge layer (ADR-012) ────────────────────────────────────────
# Master kill switch. Truthy values: 1, true, yes, on (case-insensitive).
# Leave unset to disable Neo4j wiring entirely — Phase 1 + Phase 2 + Phase 3
# all skip silently when this is off.
KW_KNOWLEDGE_LAYER_ENABLED=

# Neo4j connection. Empty `KW_NEO4J_URI` disables the bolt driver and
# falls back to the in-memory graph store (fine for tests, not for prod).
KW_NEO4J_URI=
KW_NEO4J_USER=
KW_NEO4J_PASSWORD=
KW_NEO4J_DATABASE=neo4j

# ─── LLM — Phase 2 entity extraction (ADR-013, amended §6) ────────────
# Two providers are supported behind the LLMClient Protocol. Selection
# follows KW_LLM_PROVIDER:
#   auto      — default. Gemini wins when GEMINI_API_KEY is set,
#               otherwise Anthropic. Either-or; both keys can be set
#               and the unused one stays dormant.
#   gemini    — pin Gemini; refuses to wire Phase 2 / Phase 3 if
#               GEMINI_API_KEY is missing.
#   anthropic — pin Anthropic; refuses to wire if ANTHROPIC_API_KEY
#               is missing.
KW_LLM_PROVIDER=auto

# Gemini API key. Empty disables the Gemini provider. With auto mode
# and this key set, Gemini becomes the active LLM. Accepted alias:
# KW_GEMINI_API_KEY.
GEMINI_API_KEY=

# Optional Gemini model override. Empty uses the SDK default
# (currently gemini-2.5-flash — cheap + fast tier).
KW_GEMINI_MODEL=

# Anthropic API key. Empty disables the Anthropic provider. Acts as
# the fallback in auto mode when GEMINI_API_KEY is unset.
ANTHROPIC_API_KEY=

# Optional Claude model override. Empty uses the SDK default
# (currently claude-sonnet-4-5). Accepted aliases: KW_ANTHROPIC_MODEL.
KW_LLM_MODEL=

# ─── Embeddings — Phase 3 vector RAG (ADR-015) ────────────────────────
# Voyage AI API key. Empty disables Phase 3 vector mode; Phase 1 and
# Phase 2 are unaffected. Sign up at https://www.voyageai.com to issue
# a key. Accepted alias: KW_VOYAGE_API_KEY.
VOYAGE_API_KEY=

# Voyage embedding model id. Default `voyage-3` (1024-dim, asymmetric)
# matches the dimensionality the Phase 3 Neo4j vector index will be
# provisioned against. Other supported ids: voyage-3-large,
# voyage-3-lite, voyage-code-2, voyage-law-2, voyage-finance-2.
KW_EMBEDDING_MODEL=voyage-3

# ─── Demo / local persistence (issue #130) ────────────────────────────
# Truthy → API boots with the SQLite + filesystem services rooted at
# KW_DATA_DIR. Default (false) keeps the test suite booting in-memory.
KW_PERSISTENT=
KW_DATA_DIR=.kw-pipeline

# ─── Upload guardrails ────────────────────────────────────────────────
# Hard ceiling on a single upload, in bytes. Default 50 MiB.
KW_MAX_UPLOAD_BYTES=
# Comma-separated MIME allowlist for POST /documents/upload. The demo
# defaults (set by `kw-demo`) cover text, PDF, DOCX, and PPTX:
#   text/plain
#   application/pdf
#   application/vnd.openxmlformats-officedocument.wordprocessingml.document
#   application/vnd.openxmlformats-officedocument.presentationml.presentation
KW_ALLOWED_CONTENT_TYPES=

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origin allowlist. Empty (default) means no
# cross-origin requests are accepted. For the 3DX widget on S3:
#   https://3dx-kwforge-widgets.s3.eu-north-1.amazonaws.com,https://*.3dexperience.3ds.com
KW_CORS_ALLOWED_ORIGINS=

# ─── HITL routing + ITEROP external review workflow ─────────────────
# Roadmap: docs/roadmap/2026-05-04-hitl-and-extensions.md §2 (future
# ADR-024). Adapter implementation pending ITEROP auth doc; the env
# surfaces ship now so the Knowledge Forge Settings widget can render
# the deployment posture.

# Default review routing. `human` keeps every doc on the in-app
# Orbital queue. `external` hands off to ITEROP via the configured
# workflow ref. `auto` skips the review gate (test-only).
KW_HITL_DEFAULT_VALIDATION_METHOD=human

# Truthy enables the ITEROP external-review adapter. Off by default —
# `validation_method = external` falls back to the in-app queue with
# a warning when this is unset.
KW_ITEROP_ENABLED=

# ITEROP workflow id the adapter targets when issuing review packets
# (e.g. WF-KW-DOC-REVIEW-001). Visible in operator surfaces — not a
# secret.
KW_ITEROP_WORKFLOW_REF=

# Base URL of the ITEROP instance the adapter polls / callbacks.
# Empty disables external routing regardless of the kill switch.
KW_ITEROP_BASE_URL=

# Bearer token for ITEROP API calls. Empty disables external routing.
# Auth scheme (HMAC / OAuth / mTLS / opaque) is TBD pending the
# ITEROP documentation; the adapter treats this as an opaque secret.
KW_ITEROP_AUTH_TOKEN=

# ─── Logging (issue #42) ──────────────────────────────────────────────
# `text` (default) for human-readable local dev; `json` for containers.
KW_LOG_FORMAT=text
KW_LOG_LEVEL=INFO
