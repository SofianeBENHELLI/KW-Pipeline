# Operator-tunable env for the docker compose ``api`` service.
#
# Copy this to ``docker/.env`` and fill in what your deployment needs:
#
#     cp docker/.env.example docker/.env
#     ${EDITOR:-vim} docker/.env
#     docker compose -f docker/docker-compose.yml --profile dev up -d --force-recreate api
#
# Every var below maps 1:1 to the typed Settings model in
# ``apps/api/app/settings.py``. Pydantic ignores unknown env names so
# adding a new var here only takes effect once the matching field
# exists in Settings — that's the contract.
#
# Container-network-specific values (Neo4j URI, CORS regex, Phase 1
# kill switch) are HARD-CODED in ``docker-compose.yml`` so the
# operator's ``.env`` cannot accidentally point the API at a
# different Neo4j or relax the 3DEXPERIENCE origin check. If you need
# to override those, edit the compose file's ``environment:`` block.
#
# Convention: int / bool / float settings are *commented out* below
# (lines starting with ``#``). Pydantic strict-parses ``""`` and
# crashes the API on boot if you leave them assigned to empty values
# (e.g. ``KW_PERSISTENT=``). Uncomment the line and set a value to
# override the default; leave it commented to inherit the default
# from ``apps/api/app/settings.py``. ``str`` settings tolerate empty
# values so they ride through as plain ``KEY=``.

# ─── LLM provider (ADR-013) ─────────────────────────────────────────
# ``auto`` (default) prefers Gemini when its key is set, then
# Anthropic. Pin to one provider with ``gemini`` / ``anthropic``.
# Literal field — leaving the value blank crashes pydantic on boot,
# so this stays commented out unless overridden.
#KW_LLM_PROVIDER=auto

# Gemini — sign up at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override; empty uses the SDK default (gemini-2.5-flash).
KW_GEMINI_MODEL=

# Anthropic — sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional model override; empty uses the SDK default (claude-sonnet-4-5).
KW_LLM_MODEL=

# Phase 2 entity-extraction breaker (ADR-014 §3). 0 disables.
# Default 0 (disabled). Uncomment + set to a positive integer to cap.
#KW_ENTITY_EXTRACTOR_MAX_INPUT_TOKENS_PER_DOCUMENT=0

# Per-section input-token cap for the Claim extractor (#392, ADR-031).
# 0 disables (the default). Set to a positive integer to skip any
# section whose text exceeds the cap; the section is passed over with
# no LLM call and no claims are written for it.
#KW_CLAIM_EXTRACTOR_MAX_INPUT_TOKENS_PER_DOCUMENT=0

# Per-request timeout (seconds) on outbound Anthropic calls. Default 60s.
# Bounds the SDK so a stalled LLM call can't hang a worker. `0` disables.
#KW_ANTHROPIC_TIMEOUT_SECONDS=60
# Same for Gemini (HttpOptions.timeout, internally ms). Default 60s.
#KW_GEMINI_TIMEOUT_SECONDS=60

# Cap on concurrent in-flight LLM calls per process. Defaults to 4.
# Prevents a burst of validations from tripping the per-minute rate
# limit. Must be >= 1.
#KW_ANTHROPIC_MAX_CONCURRENT=4
#KW_GEMINI_MAX_CONCURRENT=4

# ─── Embeddings / Phase 3 (ADR-015) ─────────────────────────────────
# Voyage — sign up at https://www.voyageai.com
VOYAGE_API_KEY=
# Embedding model id; default ``voyage-3``.
KW_EMBEDDING_MODEL=
# Per-request timeout (seconds) on outbound Voyage calls. Default 30s.
#KW_VOYAGE_TIMEOUT_SECONDS=30
# Cap on concurrent in-flight Voyage calls per process. Default 4.
#KW_VOYAGE_MAX_CONCURRENT=4

# ─── Persistence ────────────────────────────────────────────────────
# Truthy enables SQLite-backed catalog + on-disk storage. The compose
# stack mounts a named volume at /data; the API derives sub-paths
# from KW_DATA_DIR (defaults to /data inside the container).
# Settings default is false (in-memory). Recommended for the compose
# ``deploy`` profile: true (uncomment the line below).
#KW_PERSISTENT=true
KW_DATA_DIR=

# ─── Upload guardrails ──────────────────────────────────────────────
# Hard ceiling per upload, in bytes. Default 50 MiB.
#KW_MAX_UPLOAD_BYTES=52428800
# Comma-separated MIME allowlist. Default text/plain.
KW_ALLOWED_CONTENT_TYPES=

# ─── CORS (host-side) ───────────────────────────────────────────────
# Exact origin allowlist. The 3DEXPERIENCE regex is hard-coded in
# compose; this list is for additional dev / preview origins.
KW_CORS_ALLOWED_ORIGINS=

# ─── HITL routing + ITEROP external review ──────────────────────────
# Default validation method for new docs. ``human`` = Orbital queue,
# ``external`` = ITEROP (requires the adapter), ``auto`` = test-only.
# Default ``human``.
#KW_HITL_DEFAULT_VALIDATION_METHOD=human
# Truthy enables the ITEROP adapter. When off, ``external`` falls back
# to the in-app queue with a warning. Default false.
#KW_ITEROP_ENABLED=false
KW_ITEROP_WORKFLOW_REF=
KW_ITEROP_BASE_URL=
KW_ITEROP_AUTH_TOKEN=

# ─── NER (ADR-013 §7) ───────────────────────────────────────────────
# Truthy enables the spaCy NER fallback. Empty / falsy keeps the
# pipeline LLM-only. Default false.
#KW_NER_ENABLED=false
KW_NER_SPACY_MODEL=

# ─── Audit event store (#26 / ADR-027) ──────────────────────────────
# Truthy enables the SQLite audit table. Required for the Orbital
# purge audit trail (orbital.document.purge / orbital.knowledge_space.purge).
# Settings default is false. Recommended for the compose ``deploy``
# profile: true (uncomment the line below).
#KW_AUDIT_ENABLED=true
# Absolute path to the audit SQLite file. Empty derives it from
# KW_DATA_DIR (``<data_dir>/audit.sqlite3``).
KW_AUDIT_DB_PATH=

# ─── Authentication (ADR-019) ───────────────────────────────────────
# ``dev`` (default) stamps a fixed dev admin user on every request.
# ``disabled`` is the legacy anonymous escape hatch.
# ``bearer`` requires KW_AUTH_SECRET and validates HS256 JWTs.
KW_AUTH_MODE=
KW_AUTH_DEV_USER=
# REQUIRED when KW_AUTH_MODE=bearer. Min 32 bytes.
KW_AUTH_SECRET=

# ─── Taxonomy / ontology (ADR-017) ──────────────────────────────────
# Path to the YAML taxonomy file. Empty disables the imposed
# taxonomy and the pipeline auto-deduces topics.
KW_TAXONOMY_PATH=
# Cosine similarity threshold for taxonomy classification. Default 0.55.
#KW_TAXONOMY_COSINE_THRESHOLD=0.55

# ─── Logging ────────────────────────────────────────────────────────
# ``text`` (default) or ``json``. Production deploys usually pick json.
#KW_LOG_FORMAT=text
KW_LOG_LEVEL=

# ─── Operational hardening (uptime PRs) ─────────────────────────────
# Periodic stuck-extraction recovery interval (seconds). Default 900
# (15 min). `0` disables; the boot-time scan always runs.
#KW_EXTRACTION_RECOVERY_INTERVAL_SECONDS=900

# Periodic SQLite catalog backup (online; no writer lock).
# Defaults: 86400s (24h) interval, 7 snapshots retained.
#KW_BACKUP_INTERVAL_SECONDS=86400
#KW_BACKUP_RETAIN_COUNT=7

# Periodic Neo4j knowledge-graph backup (#381 / ADR-031). Defaults
# 0 (disabled) — operator opts in based on Neo4j edition + deployment
# topology. At the target catalog scale (100k+ chunks) re-projecting
# from SQLite is hours of recovery time, so periodic Neo4j dumps
# keep the recovery window short.
#
# Required when KW_NEO4J_BACKUP_INTERVAL_SECONDS > 0:
#   KW_NEO4J_BACKUP_DIR — writable directory for dumps. Each cycle
#   creates a timestamped subdirectory inside.
#
# The default command assumes Community + co-located neo4j-admin.
# Override the template for Enterprise online backup, sidecar
# tooling, or a webhook-driven backup orchestrator. Placeholders:
# {database}, {dest_dir}, {timestamp}.
#KW_NEO4J_BACKUP_INTERVAL_SECONDS=0
#KW_NEO4J_BACKUP_RETAIN_COUNT=7
KW_NEO4J_BACKUP_DIR=
KW_NEO4J_BACKUP_COMMAND=

# Opt-in async knowledge projection. Default false (preserves
# historical "graph available immediately after validate" contract).
#KW_KNOWLEDGE_PROJECTION_ASYNC=false
# Drain cap (seconds) for in-flight async projection on shutdown.
#KW_BACKGROUND_TASK_SHUTDOWN_TIMEOUT_SECONDS=30

# ─── AURA companion (ADR-029, EPIC #373) ────────────────────────────
# Default-deny trust gate for companion citations (#372). When true
# (the default), grounded answers cite only VALIDATED or
# source-backed chunks; the per-call ``widen=true`` toggle is
# ignored. Regulated deployments leave this on. Set to false to let
# end-users widen via the companion UI.
#KW_COMPANION_TRUST_GATE_STRICT=true

# Per-citation feedback bridge (#371). When a chunk accumulates this
# many distinct-user "wrong" reactions in the rolling window, the
# chunk's parent document version is promoted into the Orbital
# re-review queue with reason "companion_feedback_wrong". Defaults
# 3 reactions / 14 days. Both must be >= 1.
#KW_COMPANION_FEEDBACK_WRONG_THRESHOLD=3
#KW_COMPANION_FEEDBACK_WINDOW_DAYS=14
