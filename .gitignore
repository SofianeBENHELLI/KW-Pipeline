__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv*/
venv/
node_modules/
# Secrets — every variant of `.env` except the committed template.
# `.env.example` is force-included via the `!` rule so contributors
# can still see the schema; everything else is ignored by default.
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# AWS credentials — belt-and-braces guard alongside `.env*` and the
# gitleaks pre-commit hook. Real credentials live in `~/.aws/` on a
# developer's machine or in a CI secret manager — never in the repo.
**/aws/credentials
**/aws/credentials.local
.aws/credentials
.aws/credentials.local
*aws-credentials*
*.aws-credentials
.DS_Store
*.egg-info/
.kw-pipeline/
.coverage
.coverage.*
coverage.xml
htmlcov/
pytest-junit.xml

# Local Claude Code agent worktree state — never commit.
.claude/worktrees/
